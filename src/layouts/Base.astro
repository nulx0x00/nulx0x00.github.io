---
import '../styles/global.css';

const { title = 'NulX0x00', description = 'Security researcher. Red team. Bug bounty hunter.' } = Astro.props;
const currentPath = Astro.url.pathname;

const nav = [
  { href: '/',          label: '~/home'     },
  { href: '/journey',   label: '~/journey'  },
  { href: '/bounties',  label: '~/bounties' },
  { href: '/blog',      label: '~/blog'     },
  { href: '/projects',  label: '~/projects' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — NulX0x00</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

<!-- Custom cursor -->
<div id="cursor"></div>
<div id="cursor-ring"></div>


<header>
  <nav class="container">
    <a href="/" class="nav-brand">NulX0x00<span class="cursor"></span></a>
    <ul class="nav-links">
      {nav.map(({ href, label }) => (
        <li>
          <a href={href} class={currentPath === href ? 'active' : ''}>{label}</a>
        </li>
      ))}
    </ul>
    <a
      href="https://github.com/nulx0x00"
      target="_blank"
      rel="noopener"
      class="nav-gh"
      aria-label="GitHub"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
        0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52
        -.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2
        -3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64
        -.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12
        .51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93
        -.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
    </a>
  </nav>
</header>

<main>
  <slot />
</main>

<footer>
  <div class="container">
    <span class="footer-left">root@NulX0x00:~$ <span style="color:var(--green)">echo "stay curious"</span></span>
    <span class="footer-right">built with Astro · deployed on Vercel</span>
  </div>
</footer>

</body>
</html>

<style>
  /* ── Custom cursor ── */
  * { cursor: none; }

  #cursor {
    position: fixed;
    width: 10px;
    height: 10px;
    background: var(--green);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transition: transform 0.1s;
  }

  #cursor-ring {
    position: fixed;
    width: 36px;
    height: 36px;
    border: 2px solid var(--green);
    border-radius: 50%;
    pointer-events: none;
    z-index: 9998;
    opacity: 0.5;
    transition: width 0.2s, height 0.2s, opacity 0.2s;
  }

header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(10, 12, 15, 0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
nav {
  display: flex;
  align-items: center;
  gap: 2rem;
  padding-top: 0.8rem;
  padding-bottom: 0.8rem;
}
.nav-brand {
  font-family: var(--sans);
  font-size: 1.1rem;
  font-weight: 800;
  color: #fff;
  white-space: nowrap;
}
.nav-links {
  display: flex;
  list-style: none;
  gap: 0.25rem;
  flex: 1;
}
.nav-links a {
  color: var(--text-dim);
  font-size: 0.75rem;
  padding: 0.3rem 0.75rem;
  border-radius: 4px;
  transition: all 0.15s;
  border: 1px solid transparent;
}
.nav-links a:hover,
.nav-links a.active {
  color: var(--green);
  background: var(--green-glow);
  border-color: var(--border);
  opacity: 1;
}
.nav-gh {
  color: var(--text-dim);
  display: flex;
  align-items: center;
  transition: color 0.15s;
}
.nav-gh:hover { color: var(--green); opacity: 1; }

footer {
  border-top: 1px solid var(--border);
  margin-top: 6rem;
  padding: 1.5rem 0;
  font-size: 0.7rem;
  color: var(--text-dim);
}
footer .container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.5rem;
}
</style>

<script>
  const cursor = document.getElementById('cursor');
  const ring = document.getElementById('cursor-ring');
  let mx = 0, my = 0, rx = 0, ry = 0;

  document.addEventListener('mousemove', e => {
    mx = e.clientX;
    my = e.clientY;
    cursor.style.left = mx - 5 + 'px';
    cursor.style.top = my - 5 + 'px';
  });

  function animRing() {
    rx += (mx - rx - 18) * 0.12;
    ry += (my - ry - 18) * 0.12;
    ring.style.left = rx + 'px';
    ring.style.top = ry + 'px';
    requestAnimationFrame(animRing);
  }
  animRing();

  document.querySelectorAll('a, button, .path-card, .earn-card').forEach(el => {
    el.addEventListener('mouseenter', () => {
      ring.style.width = '60px';
      ring.style.height = '60px';
      ring.style.opacity = '0.8';
    });
    el.addEventListener('mouseleave', () => {
      ring.style.width = '36px';
      ring.style.height = '36px';
      ring.style.opacity = '0.5';
    });
  });
</script>